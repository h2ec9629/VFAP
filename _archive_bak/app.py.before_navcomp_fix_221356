def _get_or_open_excel():
    """既存 Excel に接続、なければ新規起動。(excel, is_new) を返す"""
    import win32com.client
    try:
        return win32com.client.GetActiveObject("Excel.Application"), False
    except Exception:
        excel = win32com.client.Dispatch("Excel.Application")
        excel.Visible = False
        return excel, True

def _get_or_open_wb(excel, path: Path):
    """Workbooks の中から path を探し、なければ Open する"""
    name = path.name.lower()
    for i in range(1, excel.Workbooks.Count + 1):
        if excel.Workbooks(i).Name.lower() == name:
            return excel.Workbooks(i)
    return excel.Workbooks.Open(str(path.resolve()))


