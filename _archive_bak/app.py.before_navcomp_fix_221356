def _sync_kakozu_status(base_dir, nittei_rows: list):
    # 日程ページ保存時に sgt_status.json の加工済ステータスを同期する
    # qty > 0 かつ done >= qty の依頼を「加工済」に更新（完了済みは除外）
    # sgt_status.json の各エントリに "no" フィールドが保存されている必要がある
    status_path = base_dir / "sgt_status.json"
    try:
        status_dict = json.loads(status_path.read_text("utf-8")) if status_path.exists() else {}
    except Exception:
        return
    # no → status_key の逆引きマップを構築
    no_to_key = {
        str(v.get("no", "")).strip(): k
        for k, v in status_dict.items()
        if v.get("no")
    }
    updated = False
    for row in nittei_rows:
        no = str(row.get("no", "")).strip()
        if not no:
            continue
        qty  = int(row.get("qty",  0) or 0)
        done = int(row.get("done", 0) or 0)
        key = no_to_key.get(no)
        if not key or key not in status_dict:
            continue
        if status_dict[key].get("status") == "完了":
            continue  # 完了済みは上書きしない
        if qty > 0 and done >= qty:
            status_dict[key]["status"] = "加工済"
            updated = True
    if updated:
        try:
            status_path.write_text(
                json.dumps(status_dict, ensure_ascii=False, indent=2), "utf-8")
        except Exception:
            pass

