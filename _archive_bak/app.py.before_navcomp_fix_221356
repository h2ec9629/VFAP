# 日程データ読み込み（nittei.json から）
# ══════════════════════════════════════════════════════════
def sync_sgt_to_nittei() -> tuple:
    """
    SGT.xlsm 日程シートの AC/AD/AF 列を nittei.json に同期する。
    D列（明細No）をキーに照合し、一致した行の
      AC列 → ac（引き取り）
      AD列 → ad（納品）
      AF列 → af（期限）
    を上書きする。
    戻り値: (更新件数: int, メッセージ: str)
    """
    nittei_path = BASE_DIR / "nittei.json"
    if not nittei_path.exists():
        nittei_path = Path(__file__).resolve().parent / "nittei.json"
    if not nittei_path.exists():
        return 0, "nittei.json が見つかりません"
    if not SGT_PATH.exists():
        return 0, "SGT.xlsm が見つかりません"

    wb = tmp_path = None
    try:
        wb, tmp_path = open_workbook_safely(
            SGT_PATH, keep_vba=True, data_only=True, read_only=True)
        ws = wb["日程"]

        # D列（col 4）をキーに AC/AD/AF を収集（row 5 以降がデータ）
        sgt_map: dict[int, dict] = {}
        sgt_order: list[int] = []
        for row in ws.iter_rows(min_row=5, values_only=True):
            d_val = row[3]   # D列 (0-indexed: 3)
            if not d_val:
                continue
            try:
                meisai_no = int(d_val)
            except (TypeError, ValueError):
                continue
            sgt_map[meisai_no] = {
                "ac":     fmt_date(row[28]),  # AC列 (0-indexed: 28)
                "ad":     fmt_date(row[29]),  # AD列 (0-indexed: 29)
                "af":     fmt_date(row[31]),  # AF列 (0-indexed: 31)
                "qty":    int(row[20]) if row[20] is not None else None,  # U列 注文数
                "done":   int(row[22]) if row[22] is not None else None,  # W列 進捗数
                "kyukyu": int(row[0])  if row[0]  is not None else None,  # A列 支給
                "shohi":  int(row[1])  if row[1]  is not None else None,  # B列 消費
                "zansu":  int(row[2])  if row[2]  is not None else None,  # C列 残数
            }
            sgt_order.append(meisai_no)

    except Exception as e:
        return 0, f"SGT 読み込みエラー: {e}"
    finally:
        try:
            if wb is not None:
                wb.close()
        except Exception:
            pass
        cleanup_tmp(tmp_path)

    try:
        rows = json.loads(nittei_path.read_text(encoding="utf-8"))
    except Exception as e:
        return 0, f"nittei.json 読み込みエラー: {e}"

    # rows を明細No でインデックス化
    rows_map = {}
    for r in rows:
        try:
            no_int = int(r.get("no", 0) or 0)
        except (TypeError, ValueError):
            no_int = 0
        rows_map[no_int] = r

    # AC/AD/AF/qty/done/kyukyu/shohi/zansu を上書き（SGT が正）
    updated = 0
    for no_int, r in rows_map.items():
        if no_int in sgt_map:
            sg = sgt_map[no_int]
            changed = False
            # 日付フィールド：空値はスキップ
            for key in ("ac", "ad", "af"):
                val = sg[key]
                if val and r.get(key) != val:
                    r[key] = val
                    changed = True
            # 数値フィールド：None 以外はすべて上書き（0 も有効値）
            for key in ("qty", "done", "kyukyu", "shohi", "zansu"):
                val = sg[key]
                if val is not None and r.get(key) != val:
                    r[key] = val
                    changed = True
            if changed:
                updated += 1

    # SGT の行順に並び替え（SGTにない行は末尾）
    sgt_set = set(sgt_order)
    sorted_rows = (
        [rows_map[no] for no in sgt_order if no in rows_map]
        + [r for no, r in rows_map.items() if no not in sgt_set]
    )

    try:
        nittei_path.write_text(
            json.dumps(sorted_rows, ensure_ascii=False, indent=2), encoding="utf-8")
    except Exception as e:
        return 0, f"nittei.json 書き込みエラー: {e}"

    _gist_push_async()  # SGT同期後にGistへ自動push
    return updated, f"{updated} 件を SGT から同期しました"


def load_nittei_rows() -> list:
    nittei_path = BASE_DIR / "nittei.json"
    if not nittei_path.exists():
        # フォールバック：app.pyと同階層も探す
        nittei_path = Path(__file__).resolve().parent / "nittei.json"
