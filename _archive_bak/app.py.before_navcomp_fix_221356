def normalize_path(p: str) -> str:
    """ユーザー名依存をなくすパス正規化"""
    import re as _re_np
    s = str(Path(p)).lower()
    # c:\users\<誰でも>\ → c:\users\_\ に統一してユーザー名差異を吸収
    s = _re_np.sub(r"(^[a-z]:\\users\\)[^\\]+\\", r"\1_\\", s)
    return s

def calc_hours(suryo, kosuu):
    """加工時間(h) = 数量 ÷ 切断工数(本/h)"""
    try:
        return round(float(suryo) / float(kosuu), 1)
    except Exception:
        return None

def calc_days(hours):
    """加工日数 = ceil(時間 ÷ 8h)"""
    try:
        return math.ceil(float(hours) / 8)
    except Exception:
        return None

def fmt_date(val):
    """日付を mm/dd 形式に"""
    if val is None:
        return ""
    if isinstance(val, (datetime,)):
        return val.strftime("%m/%d")
    try:
        return pd.to_datetime(val).strftime("%m/%d")
    except Exception:
        return str(val)

def fmt_datetime(val):
    """更新日時を mm/dd HH:MM 形式に"""
    if val is None:
        return ""
    if isinstance(val, (datetime,)):
        return val.strftime("%m/%d %H:%M")
    try:
        return pd.to_datetime(val).strftime("%m/%d %H:%M")
    except Exception:
        return str(val)

def get_mtime(file_path):
    """ファイルの最終更新日時を datetime で返す（取れなければ None）"""
    try:
        p = Path(file_path)
        if p.exists():
            return datetime.fromtimestamp(p.stat().st_mtime)
    except Exception:
        pass
    return None

def open_workbook_safely(path: Path, **kwargs):
    """
    Excelで開きっぱなしの SGT.xlsm でも読めるよう、
    まず普通に開き、ロックで失敗したら一時コピー経由で開く。
    戻り値: (workbook, tmp_path)  tmp_path は使い終わったら削除する
    """
    # まず通常オープンを試す
    try:
        wb = openpyxl.load_workbook(str(path), **kwargs)
        return wb, None
    except (PermissionError, OSError):
        pass

    # 失敗したら一時フォルダにコピーしてから開く（排他ロック回避）
    tmp_dir  = tempfile.gettempdir()
    tmp_path = Path(tmp_dir) / f"_sgt_tmp_{os.getpid()}_{path.name}"
    shutil.copy2(str(path), str(tmp_path))
    wb = openpyxl.load_workbook(str(tmp_path), **kwargs)
    return wb, tmp_path

def cleanup_tmp(tmp_path):
    """一時コピーの後片付け"""
    if tmp_path:
        try:
            os.remove(str(tmp_path))
        except Exception:
            pass

