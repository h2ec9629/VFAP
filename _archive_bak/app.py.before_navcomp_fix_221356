def _auto_assign_denno_and_save() -> dict:
    """denno未設定 & ad設定済みの行を自動採番して nittei.json に上書き保存し、no→row の dict を返す。"""
    _cands = [BASE_DIR / "nittei.json", Path(__file__).resolve().parent / "nittei.json"]
    _p = next((c for c in _cands if c.exists()), None)
    if _p is None:
        return {}
    try:
        _rows = json.loads(_p.read_text(encoding="utf-8"))
    except Exception:
        return {}

    _unassigned = [r for r in _rows if not r.get("denno") and r.get("ad")]
    if not _unassigned:
        return {str(r.get("no", "")).lstrip("0"): r for r in _rows}

    # 月ごとの既存 denno 最大連番
    _month_max = {}
    for _r in _rows:
        if _r.get("denno") and _r.get("ad"):
            try:
                _m = int(_r["ad"].split("/")[0])
                _prefix = f"{_m}-"
                if _r["denno"].startswith(_prefix):
                    _n = int(_r["denno"].split("-")[1])
                    _month_max[_m] = max(_month_max.get(_m, 0), _n)
            except (IndexError, ValueError):
                pass

    # 納品日ごとの既存 denno 使用数
    _ad_denno_count = {}
    for _r in _rows:
        if _r.get("denno") and _r.get("ad"):
            _ad_denno_count.setdefault(_r["ad"], {})
            _ad_denno_count[_r["ad"]][_r["denno"]] = _ad_denno_count[_r["ad"]].get(_r["denno"], 0) + 1

    # 未採番を納品日でグループ化 → 日付昇順
    _groups = {}
    for _r in _unassigned:
        _groups.setdefault(_r["ad"], []).append(_r)
    _sorted_dates = sorted(_groups.keys(), key=lambda d: tuple(int(x) for x in d.split("/")))

    _changed = 0
    for _date in _sorted_dates:
        _m = int(_date.split("/")[0])
        _prefix = f"{_m}-"
        if _m not in _month_max:
            _month_max[_m] = 0
        _grp = _groups[_date]
        _existing = _ad_denno_count.get(_date, {})
        # 空きスロット（<7件）がある既存 denno を先に使う
        _sorted_ex = sorted(
            _existing.keys(),
            key=lambda d: int(d.split("-")[1]) if "-" in d else 0
        )
        _cur_denno, _cur_count = None, 0
        for _d in _sorted_ex:
            if _existing[_d] < 7:
                _cur_denno, _cur_count = _d, _existing[_d]
                break
        for _r in _grp:
            if not _cur_denno or _cur_count >= 7:
                _month_max[_m] += 1
                _cur_denno = f"{_prefix}{_month_max[_m]}"
                _cur_count = 0
                _ad_denno_count.setdefault(_date, {})
            _r["denno"] = _cur_denno
            _ad_denno_count[_date][_cur_denno] = _ad_denno_count[_date].get(_cur_denno, 0) + 1
            _cur_count += 1
            _changed += 1

    if _changed:
        try:
            _p.write_text(json.dumps(_rows, ensure_ascii=False, indent=2), encoding="utf-8")
            _pdf_debug_log(f"[採番] {_changed}件に伝票Noを自動採番してnittei.jsonを保存しました")
        except Exception as _e:
            _pdf_debug_log(f"[採番] nittei.json保存エラー: {_e}")

    return {str(r.get("no", "")).lstrip("0"): r for r in _rows}

def _make_meisaisho_pdf(ad_str: str, items: list, out_path) -> tuple:
    """
    納品明細書 PDF (A4横) - SGT Excel 納品明細書シートに準拠
    """
    try:
        import os as _os
        from reportlab.pdfgen import canvas as _rlc
        from reportlab.lib.pagesizes import A4 as _A4, landscape as _landscape
        from reportlab.pdfbase import pdfmetrics as _pm
        from reportlab.pdfbase.ttfonts import TTFont as _TTF

        # ── フォント（游ゴシック→メイリオ→MSゴシック の順で試行）──
        _JA, _JA_B = "Helvetica", "Helvetica-Bold"
        for _fp, _ni, _bi in [
            (r"C:\Windows\Fonts\YuGothM.ttc",  0, 0),
            (r"C:\Windows\Fonts\meiryo.ttc",   0, 1),
            (r"C:\Windows\Fonts\msgothic.ttc", 0, 2),
        ]:
            if _os.path.exists(_fp):
                try:
                    _pm.registerFont(_TTF("_MSN_ms", _fp, subfontIndex=_ni))
                    _JA = "_MSN_ms"
                    try:
                        _pm.registerFont(_TTF("_MSB_ms", _fp, subfontIndex=_bi))
                        _JA_B = "_MSB_ms"
                    except Exception:
                        _JA_B = _JA
                    break
                except Exception:
                    continue

        # ── ページ・マージン ──
        _W, _H = _landscape(_A4)   # 841.89 × 595.28 pt
        _PT    = 2.83465
        _ML    = 14 * _PT
        _MR    = 14 * _PT
        _MT    = 12 * _PT
        _MB    = 10 * _PT
        _TW    = _W - _ML - _MR

        # ── 納品日表示 ──
        try:
            _ms, _ds = ad_str.split("/")
            _yr = datetime.now().year
            _date_disp = f"{_yr}年{int(_ms)}月{int(_ds)}日"
        except Exception:
            _date_disp = ad_str

        # ── 伝票No集計 ──
        _dn_rows = {}
        for _it in items:
            _dn = str(_it.get("denno") or "—")
            _dn_rows.setdefault(_dn, []).append(_it["row_no"])
        _denno_list = []
        for _dn, _rns in sorted(_dn_rows.items(), key=lambda kv: kv[1][0]):
            _dn_disp = _dn.replace("-", "ー") if _dn != "—" else _dn
            _denno_list.append((f"番号　{min(_rns)}～{max(_rns)}", _dn_disp))

        _c = _rlc.Canvas(str(out_path), pagesize=(_W, _H))

        # ──────────────────────────────────────
        # ヘッダー（Excel rows 2-4 相当）
        # ──────────────────────────────────────
        _ty = _H - _MT

        # 左ボックス（SGT D2:F3 + D4:F4 相当）
        _BW     = 158
        _BH_TTL = 64    # 「納品明細書」エリア（rows 2-3）
        _BH_DT  = 34    # 日付エリア（row 4）
        _BH     = _BH_TTL + _BH_DT

        # 外枠（太線）
        _c.setLineWidth(1.8)
        _c.rect(_ML, _ty - _BH, _BW, _BH)
        # タイトル / 日付 仕切り線
        _c.setLineWidth(0.8)
        _c.line(_ML, _ty - _BH_TTL, _ML + _BW, _ty - _BH_TTL)

        # 「納品明細書」
        _c.setFont(_JA_B, 21)
        _c.drawCentredString(_ML + _BW / 2, _ty - _BH_TTL / 2 - 8, "納 品 明 細 書")

        # 日付
        _c.setFont(_JA_B, 12)
        _c.drawCentredString(_ML + _BW / 2, _ty - _BH_TTL - _BH_DT / 2 - 4,
                             _date_disp + "納品分")

        # 伝票No セクション（Excel H3:J4 相当）
        _dx          = _ML + _BW + 22
        _dn_section_w = 130

        _c.setFont(_JA_B, 12)
        _c.drawString(_dx, _ty - 14, "伝票No")

        _n_dn = max(len(_denno_list), 1)
        _dn_slot_h = (_BH_TTL - 18) / _n_dn
        for _i, (_rng, _dn_d) in enumerate(_denno_list):
            _dy = _ty - 18 - _dn_slot_h * (_i + 0.5)
            if _i == 0:
                _c.setLineWidth(0.6)
                _c.line(_dx, _dy + _dn_slot_h / 2 + 2,
                        _dx + _dn_section_w, _dy + _dn_slot_h / 2 + 2)
            _c.setLineWidth(0.6)
            _c.line(_dx, _dy - _dn_slot_h / 2 + 2,
                    _dx + _dn_section_w, _dy - _dn_slot_h / 2 + 2)
            _c.setFont(_JA_B, 11)
            _c.drawString(_dx + 2, _dy - 4, _rng)
            _c.setFont(_JA_B, 16)
            _c.drawString(_dx + 82, _dy - 6, _dn_d)

        # 会社情報（Excel L2:O4 相当）
        _rx = _W - _MR - 185
        _c.setFont(_JA_B, 14)
        _c.drawString(_rx, _ty - 15, "黒部工業株式会社")
        _c.setFont(_JA_B, 11)
        _c.drawString(_rx + 118, _ty - 15, "〒938-0005")
        _c.setFont(_JA_B, 12)
        _c.drawString(_rx, _ty - 33, "富山県下新川郡入善町新屋2220")
        _c.setFont(_JA, 10)
        _c.drawString(_rx, _ty - 51, "TEL：0765-78-2383　FAX：0765-78-2384")

        # ──────────────────────────────────────
        # テーブル（Excel rows 7-21 相当）
        # ──────────────────────────────────────
        _TABLE_TOP = _ty - _BH - 8

        # 列幅：品名を広くするためLot列を圧縮（Lot日16→11, Lot箱10→7, 削減40u分を品名へ）
        _COL_UNITS = [5.25, 11.75, 69.625, 12.75, 11.625] + [11, 7] * 5
        _scale = _TW / sum(_COL_UNITS)
        _CW = [u * _scale for u in _COL_UNITS]

        _N_LOTS = 5
        _HDR1_H = 19    # ヘッダー1段（加工Lot内訳スパン）
        _HDR2_H = 17    # ヘッダー2段（個別列名）
        _HDR_H  = _HDR1_H + _HDR2_H
        _N_ROWS = 14

        _AVAIL_H = _TABLE_TOP - _MB
        _ROW_H   = (_AVAIL_H - _HDR_H) / _N_ROWS

        def _cx(ci):
            return _ML + sum(_CW[:ci])

        _lot_x1 = _cx(5)
        _lot_x2 = _ML + sum(_CW)

        # ── ヘッダー（全体を同一グレーで1ブロック）──
        _y = _TABLE_TOP
        _c.setFillColorRGB(0.82, 0.82, 0.82)
        _c.rect(_ML, _y - _HDR_H, _TW, _HDR_H, fill=1, stroke=0)
        _c.setFillColorRGB(0, 0, 0)

        # 固定列ラベル（縦中央）
        _hdrs1 = ["番\n号", "明細書No", "品　　名", "数量\n(不良数)", "箱\n数"]
        for _ci, _h in enumerate(_hdrs1):
            _cx2 = _cx(_ci) + _CW[_ci] / 2
            _c.setFont(_JA_B, 8)
            if "\n" in _h:
                _ls = _h.split("\n")
                _c.drawCentredString(_cx2, _y - _HDR_H / 2 - 1, _ls[0])
                _c.drawCentredString(_cx2, _y - _HDR_H / 2 - 9, _ls[1])
            else:
                _c.drawCentredString(_cx2, _y - _HDR_H / 2 - 4, _h)

        # 「加工Lot内訳」スパン（上段）
        _c.setFont(_JA_B, 10)
        _c.drawCentredString((_lot_x1 + _lot_x2) / 2, _y - _HDR1_H / 2 - 4,
                             "加　工　Ｌｏｔ　内　訳")
        # 仕切り線（加工Lot内訳 / 個別ラベル）
        _c.setLineWidth(0.4)
        _c.line(_lot_x1, _y - _HDR1_H, _lot_x2, _y - _HDR1_H)

        # Lot個別ラベル（下段）
        _c.setFont(_JA, 7)
        for _li in range(_N_LOTS):
            _ci_d = 5 + _li * 2
            _ci_h = 6 + _li * 2
            _lot_num = "①②③④⑤"[_li]
            _c.drawCentredString(_cx(_ci_d) + _CW[_ci_d] / 2, _y - _HDR_H + 5,
                                 f"Lot{_lot_num}")
            _c.drawCentredString(_cx(_ci_h) + _CW[_ci_h] / 2, _y - _HDR_H + 5, "箱")

        # ── ヘッダー罫線 ──
        _c.setLineWidth(0.5)
        # 固定列（番号〜箱数）：全高
        for _ci in range(6):
            _xx = _cx(_ci)
            _c.line(_xx, _y, _xx, _y - _HDR_H)
        # Lot列：「加工Lot内訳」段（上段）は縦線なし → 下段のみ
        for _ci in range(5, len(_CW) + 1):
            _xx = _cx(_ci) if _ci < len(_CW) else _ML + sum(_CW)
            _c.line(_xx, _y - _HDR1_H, _xx, _y - _HDR_H)
        # Lot列左端（_lot_x1）と右端は全高
        _c.line(_lot_x1, _y, _lot_x1, _y - _HDR_H)
        _c.line(_ML + sum(_CW), _y, _ML + sum(_CW), _y - _HDR_H)
        _c.setLineWidth(0.8)
        _c.line(_ML, _y,          _ML + sum(_CW), _y)
        _c.line(_ML, _y - _HDR_H, _ML + sum(_CW), _y - _HDR_H)

        # ── データ行 ──
        _y -= _HDR_H
        _items_pad = list(items) + [None] * (_N_ROWS - len(items))
        for _ri, _it in enumerate(_items_pad):
            _ry = _y - _ROW_H
            if _ri % 2 == 1:
                _c.setFillColorRGB(0.95, 0.95, 0.97)
                _c.rect(_ML, _ry, _TW, _ROW_H, fill=1, stroke=0)
            _c.setFillColorRGB(0, 0, 0)
            _c.setLineWidth(0.3)
            for _ci in range(len(_CW) + 1):
                _xx = _cx(_ci) if _ci < len(_CW) else _ML + sum(_CW)
                _c.line(_xx, _y, _xx, _ry)
            _c.line(_ML, _ry, _ML + sum(_CW), _ry)

            # 番号列は常に 1-14 表示
            _mid_y = _ry + _ROW_H / 2 - 3
            _c.setFont(_JA_B, 10)
            _c.drawCentredString(_cx(0) + _CW[0] / 2, _mid_y, str(_ri + 1))

            if _it:
                _mn = str(_it.get("meisai_no", "")).lstrip("0")
                _c.setFont(_JA, 8)
                _c.drawCentredString(_cx(1) + _CW[1] / 2, _mid_y, _mn)
                _hn = str(_it.get("hinmei", ""))
                _fs_h = 9 if len(_hn) <= 30 else (8 if len(_hn) <= 42 else 7)
                _c.setFont(_JA, _fs_h)
                _c.drawString(_cx(2) + 2, _mid_y, _hn)
                _qty = _it.get("qty", 0) or 0
                _fur = _it.get("furyou", 0) or 0
                _c.setFont(_JA, 9)
                if _fur:
                    _c.drawCentredString(_cx(3) + _CW[3] / 2, _mid_y + 5, str(_qty))
                    _c.setFont(_JA, 7)
                    _c.drawCentredString(_cx(3) + _CW[3] / 2, _mid_y - 5, f"({_fur})")
                else:
                    _c.drawCentredString(_cx(3) + _CW[3] / 2, _mid_y, str(_qty))
                _hako = _it.get("hako", 0) or 0
                _c.setFont(_JA, 9)
                _c.drawCentredString(_cx(4) + _CW[4] / 2, _mid_y,
                                     str(_hako) if _hako else "")
                _lots = _it.get("lots") or []
                for _li, _lot_e in enumerate(_lots[:_N_LOTS]):
                    if isinstance(_lot_e, (list, tuple)):
                        _ld, _lh = _lot_e[0], _lot_e[1]
                    else:
                        _ld = _lot_e.get("lot", "")
                        _lh = _lot_e.get("hako", 0)
                    _ci_d = 5 + _li * 2
                    _ci_h = 6 + _li * 2
                    _c.setFont(_JA, 7.5)
                    if _ld:
                        _c.drawCentredString(_cx(_ci_d) + _CW[_ci_d] / 2, _mid_y,
                                             str(_ld).replace(".", ","))
                    if _lh:
                        _c.drawCentredString(_cx(_ci_h) + _CW[_ci_h] / 2, _mid_y,
                                             str(_lh) + "箱")
            _y -= _ROW_H

        # テーブル外枠（太線）
        _c.setLineWidth(1.0)
        _c.rect(_ML, _MB, _TW, _TABLE_TOP - _MB)

        _c.save()
        return True, str(out_path)

    except Exception as _ex:
        import traceback as _tb
        _err_msg = f"納品明細書PDF生成エラー: {_ex}\n{_tb.format_exc()}"
        _pdf_debug_log(_err_msg)
        return False, _err_msg


def _fill_jisseki(file_path: str, page_num: int, order: dict,
                  kakou: dict, vf: dict) -> tuple:
    """openpyxl で帳票エリア (rows 38-55) に実績値を書き込む"""
    try:
        import json as _json, unicodedata as _ud, re as _re2, time as _time
        from openpyxl.cell.cell import MergedCell as _MC
        from openpyxl.styles import PatternFill as _PFill

        # LibreOffice/OneDrive のファイルロック解放待ちリトライ
        _wb_loaded = False
        for _retry in range(6):
            try:
                wb = openpyxl.load_workbook(file_path)
                _wb_loaded = True
                break
            except PermissionError:
                if _retry < 5:
                    _time.sleep(2)
        if not _wb_loaded:
            wb = openpyxl.load_workbook(file_path)  # 最後に例外を通す
        ws = wb.active
        pr = 38 + (page_num - 1) * 57  # 帳票先頭行

        def _wc(row, col, val):
            """マージセルセーフな書き込み（絶対行番号で指定）"""
            cell = ws.cell(row, col)
            if isinstance(cell, _MC):
                # マージ範囲の左上セルを探して書き込む
                for rng in ws.merged_cells.ranges:
                    if (rng.min_row <= row <= rng.max_row and
                            rng.min_col <= col <= rng.max_col):
                        ws.cell(rng.min_row, rng.min_col).value = val
                        return
            else:
                cell.value = val

        def _w(row_off, col, val):
            if val is not None and val != "" and val != 0:
                _wc(pr + row_off, col, val)

        def _to_num(v):
            try:
                return float(str(v).replace(",", "").strip())
            except Exception:
                return None

        furyou      = kakou.get("furyou") or {}
        furyou_keys = ["kizu","kubomi","imono","kake","meyani","beko","osen","keijo","sonota"]
        furyou_lbls = ["キズ","凹み","異物","欠け","メヤニ","ベコツキ","汚損","形状異常","その他"]
        sei_furyou  = sum((furyou.get(k) or 0) for k in furyou_keys)
        toru        = int(_to_num(vf.get("取数")) or 1) or 1

        # ── ondan_lookup から換算センター値を引くヘルパー ──
        try:
            _up3 = os.environ.get("USERPROFILE", "")
            _ondan_candidates = [
                *([((detect_onedrive_work() or Path()) / "VFAP" / "ondan_lookup.json")] if _up3 else []),
                Path(__file__).resolve().parent / "ondan_lookup.json",
            ]
            _ondan_path = next((p for p in _ondan_candidates if p.exists()), None)
            _ondan_data = _json.loads(_ondan_path.read_text("utf-8")) if _ondan_path else []
        except Exception:
            _ondan_data = []

        def _lookup_kanzan(ondo_val):
            """品名 + ondo から換算センター値を返す。見つからなければ None"""
            if not _ondan_data or not ondo_val:
                return None
            hinmei = order.get("品名") or ""
            def _norm(s):
                return _re2.sub(r"\s+", "", _ud.normalize("NFKC", str(s or "")))
            norm_h  = _norm(hinmei)
            ondo_str = str(int(float(ondo_val)))
            for item in _ondan_data:
                if _norm(item.get("base", "")) == norm_h:
                    vals = item.get("temps", {}).get(ondo_str)
                    return vals[1] if (vals and len(vals) >= 2) else None
            return None

        # ── 静的値 ──
        _w(1, 1, vf.get("温度換算"))
        _w(1, 2, vf.get("センター"))           # L寸 ← 品目スペックのセンター値
        _w(1, 3, vf.get("箱名"))
        # 使用数 = ceil(入庫数 / 梱包数)　※梱包=1箱あたりの本数(例:100本/箱)。無ければ取数で代替
        # 入庫数は kiroku③の nyuko_su、なければ受注数量で代替
        _nyuko_su = int(kakou.get("nyuko_su") or 0) or int(order.get("数量") or 0)
        _box_div  = int(_to_num(vf.get("梱包")) or 0) or toru
        _w(1, 5, math.ceil(_nyuko_su / _box_div) if _nyuko_su else None)
        _w(3, 1, _to_num(vf.get("上限公差")))
        _w(3, 2, vf.get("切断寸法"))
        _w(3, 4, vf.get("備考２") or None)    # 梱包行 ← hoho1
        _w(4, 4, vf.get("梱包方法") or None)  # 方法行 ← hoho2
        _w(5, 1, _to_num(vf.get("下限公差")))
        _w(5, 2, _to_num(vf.get("取数")))
        _w(5, 4, vf.get("備考１") or None)    # 備考行 ← hoho3

        # ── 実績：右側ラベル＋値 ──
        _wc(pr+1, 9, "入庫日")
        _w(1, 10, kakou.get("nyuko_bi") or None)
        _wc(pr+2, 9, "入庫数")
        _w(2, 10, kakou.get("nyuko_su") or None)
        _wc(pr+3, 9, "使用基材数")
        _w(3, 10, kakou.get("kizai_su") or None)
        _wc(pr+4, 9, "製品不良")
        if sei_furyou:
            _wc(pr+4, 10, sei_furyou)
        _wc(pr+5, 9, "基材不良")
        _w(5, 10, kakou.get("kizai_furyou") or None)
        # 端材使用（daily の keisoku_lot="端材" 行の kakou_su を合計）
        _wc(pr+6, 9, "端材使用")
        _tanzai_su = sum(int(d.get("kakou_su") or 0)
                        for d in (kakou.get("daily") or [])
                        if (d.get("keisoku_lot") or "").strip() == "端材")
        if _tanzai_su:
            _wc(pr+6, 10, _tanzai_su)

        # ── 加工Lot・箱数 (row+1〜+2 G・H、最大2Lot) ──
        lots = kakou.get("lots") or []
        if lots:
            _w(1, 7, lots[0].get("lot"))
            _w(1, 8, lots[0].get("hako"))
            if len(lots) > 1:
                _w(2, 7, lots[1].get("lot"))
                _w(2, 8, lots[1].get("hako"))
        else:
            _w(1, 7, kakou.get("kakou_lot"))
            _w(1, 8, kakou.get("hako_su"))

        # ── 作業者 (row+1 F：切断者①②, row+2 F：検査者③④) ──
        sakushas = kakou.get("sakushas") or []
        cut_str  = " / ".join(s for s in sakushas[:2] if s)
        ken_str  = " / ".join(s for s in sakushas[2:4] if s)
        if cut_str: _w(1, 6, "切断者　" + cut_str)
        if ken_str: _w(2, 6, "検査者　" + ken_str)

        # ── row+6: ArrayFormulaを上書き（作業者参照式 → 計測Lot・加工数ヘッダー）──
        _wc(pr+6, 2, "計測Lot・加工数")

        # ── データエリアをクリア（残留データ防止）──
        # rows pr+7〜pr+17、col 1-8 および 10 を書き込み前にクリアする
        for _roff in range(7, 18):
            _tr = pr + _roff
            for _col in list(range(1, 9)) + [10]:
                _c = ws.cell(_tr, _col)
                if isinstance(_c, _MC):
                    for _rng in ws.merged_cells.ranges:
                        if (_rng.min_row <= _tr <= _rng.max_row and
                                _rng.min_col <= _col <= _rng.max_col and
                                _rng.min_row >= pr + 7 and
                                _rng.min_col <= 8):
                            _tl = ws.cell(_rng.min_row, _rng.min_col)
                            if not (isinstance(_tl.value, str) and _tl.value.startswith("=")):
                                _tl.value = None
                            break
                else:
                    if not (isinstance(_c.value, str) and _c.value.startswith("=")):
                        _c.value = None

        # ── Daily data (row+7〜+15) ── ※ 加工記録1行目 = pr+7
        daily = kakou.get("daily") or []
        for i, d in enumerate(daily):
            r_off = 7 + int(d.get("row_idx") if d.get("row_idx") is not None else i)
            _w(r_off, 1, d.get("sakugyobi") or None)
            _ondo = d.get("ondo") or 0
            if _ondo:
                _wc(pr + r_off, 3, _ondo)
            _w(r_off, 5, d.get("keisoku") or None)
            _kanzan = _lookup_kanzan(_ondo)
            if _kanzan is not None:
                _wc(pr + r_off, 4, _kanzan)
            klot = (d.get("keisoku_lot") or "").strip() or None
            k_su = d.get("kakou_su") or None
            if klot and k_su:
                _wc(pr + r_off, 2, f"{klot} × {k_su}")
            elif klot:
                _wc(pr + r_off, 2, klot)

        # ── 不良内訳（col 10）── テンプレラベル位置(pr+8〜)に固定
        for i, (lbl, key) in enumerate(zip(furyou_lbls, furyou_keys)):
            v = furyou.get(key)
            if v:
                _wc(pr + 8 + i, 10, v)

        # ── ロット使用数 (col F=使用Lot, G=加工数, H=基材換算) ──
        _lot_agg: dict = {}
        _lot_order: list = []
        for d in daily:
            _lot = (d.get("keisoku_lot") or "").strip()
            _su  = int(d.get("kakou_su") or 0)
            if not _lot or _lot == "端材":
                continue
            if _lot not in _lot_agg:
                _lot_agg[_lot] = 0
                _lot_order.append(_lot)
            _lot_agg[_lot] += _su

        # 補填ロット確定（lot2が空でhotensuu>0の場合、dailyの最終lotから推定）
        _lot2  = (kakou.get("lot2") or "").strip()
        _hoten = int(kakou.get("hotensuu") or 0)
        if not _lot2 and _hoten and daily:
            for _drev in reversed(daily):
                _ll = (_drev.get("keisoku_lot") or "").strip()
                if _ll and _ll != "端材":
                    _lot2 = _ll
                    break
        # ※ 補填数はロット集計に含めない（加工数 = daily の kakou_su のみ）

        for _i, _lot in enumerate(_lot_order[:5]):
            _su = _lot_agg[_lot]
            _r  = 7 + _i
            _w(_r, 6, _lot)
            if _su:
                _w(_r, 7, _su)
                if toru:
                    _w(_r, 8, math.ceil(_su / toru))

        # ── 補填行（row+17 col 2）：補填Lot × hotensuu を書き込む ──
        if _hoten:
            _hoten_str = f"{_lot2} × {_hoten}" if _lot2 else f"× {_hoten}"
            _wc(pr + 17, 2, _hoten_str)

        # ── 合計（テンプレにラベル静的あり、値のみ書き込む）──
        if sei_furyou:
            _wc(pr+17, 10, sei_furyou)

        # ── データエリア(pr+7〜pr+17)の行高さを統一（LibreOffice描画ズレ対策）──
        for _rh in range(7, 18):
            ws.row_dimensions[pr + _rh].height = 18.95

        # ── 使用Lot 行1・行11 を白背景（左側加工記録との視覚的連動）──
        _white_fill = _PFill(fill_type="solid", fgColor="FFFFFFFF")
        for _wr in [pr + 7, pr + 17]:
            _c6 = ws.cell(_wr, 6)
            if isinstance(_c6, _MC):
                for _rng in ws.merged_cells.ranges:
                    if (_rng.min_row <= _wr <= _rng.max_row and
                            _rng.min_col <= 6 <= _rng.max_col):
                        ws.cell(_rng.min_row, _rng.min_col).fill = _white_fill
                        break
            else:
                _c6.fill = _white_fill

        wb.save(file_path)
        return True, "書き込み完了"
    except Exception as e:
        import traceback
        return False, f"書き込みエラー: {traceback.format_exc()}"


def _find_soffice():
    """LibreOffice (soffice.exe) の場所を探す"""
    candidates = [
        Path(os.environ.get("ProgramFiles", r"C:\Program Files")) / "LibreOffice" / "program" / "soffice.exe",
        Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")) / "LibreOffice" / "program" / "soffice.exe",
    ]
    for p in candidates:
        if p.exists():
            return str(p)
    return shutil.which("soffice")


def _find_pdftk():
    """PDFtk (pdftk.exe) の場所を探す"""
    candidates = [
        Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")) / "PDFtk" / "bin" / "pdftk.exe",
        Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")) / "PDF Labs" / "PDFtk" / "bin" / "pdftk.exe",
        Path(os.environ.get("ProgramFiles", r"C:\Program Files")) / "PDFtk Server" / "bin" / "pdftk.exe",
    ]
    for p in candidates:
        if p.exists():
            return str(p)
    return shutil.which("pdftk")


def _pdf_debug_log(text: str):
    """VFAP\\pdf_debug.log に追記（成否どちらも残す）"""
    try:
        _log_path = Path(__file__).resolve().parent / "pdf_debug.log"
        with open(_log_path, "a", encoding="utf-8") as _lf:
            _lf.write(f"\n===== {datetime.now():%Y-%m-%d %H:%M:%S} =====\n{text}\n")
    except Exception:
        pass


def _export_pdf_direct(file_path: str, page_num: int, pdf_path: str) -> tuple:
    """
    LibreOffice headless で xlsx を PDF に変換し、PDFtk で該当ページを抜き出す。
    Excel COM は使わない（COM の Workbooks.Open がこの種のファイルを拒否するため）。
    - 全ページ変換した PDF は TEMP にキャッシュし、同一ファイル複数ページの
      連続出力では 2 ページ目以降の変換をスキップする（xlsx 更新時は再変換）
    """
    if not Path(file_path).exists():
        return False, f"ファイルが見つかりません: {file_path}"

    _abs_path = Path(file_path).resolve()
    _pdf_path = Path(pdf_path).resolve()

    # OneDrive「クラウドのみ」対策：変換前に必ず実体化する
    try:
        with open(_abs_path, "rb") as _hf:
            _hf.read(8)
    except OSError as _he:
        return False, f"ファイル実体化失敗（OneDrive未ダウンロード？）: {_he}"

    soffice = _find_soffice()
    if not soffice:
        return False, "LibreOffice が見つかりません（PDF変換に必要です）"
    pdftk = _find_pdftk()
    if not pdftk:
        return False, "PDFtk が見つかりません（ページ抽出に必要です）"

    import tempfile as _tmpmod
    import hashlib as _hashmod
    _cache_root = Path(os.environ.get("TEMP", _tmpmod.gettempdir())) / "lo_pdf_cache"
    _sub = _hashmod.md5(str(_abs_path).encode("utf-8")).hexdigest()[:12]
    _cache_dir = _cache_root / _sub
    _cache_dir.mkdir(parents=True, exist_ok=True)
    _full_pdf = _cache_dir / (_abs_path.stem + ".pdf")

    try:
        # ── ① xlsx → PDF（全ページ）。キャッシュが新しければスキップ ──
        _need_convert = (not _full_pdf.exists()
                         or _full_pdf.stat().st_mtime < _abs_path.stat().st_mtime)
        if _need_convert:
            _res = subprocess.run(
                [soffice, "--headless", "--norestore",
                 "--convert-to", "pdf", "--outdir", str(_cache_dir), str(_abs_path)],
                capture_output=True, text=True, timeout=180,
                encoding="cp932", errors="replace",
            )
            if not _full_pdf.exists():
                _pdf_debug_log(
                    f"LO変換失敗\nxlsx: {_abs_path}\nexit: {_res.returncode}\n"
                    f"stdout:\n{_res.stdout}\nstderr:\n{_res.stderr}"
                )
                return False, f"LibreOffice変換失敗: {(_res.stderr or _res.stdout or '').strip()[:300]}"

        # ── ② 該当ページを PDFtk で抽出 ──
        _pdf_path.parent.mkdir(parents=True, exist_ok=True)
        _res2 = subprocess.run(
            [pdftk, str(_full_pdf), "cat", str(int(page_num)), "output", str(_pdf_path)],
            capture_output=True, text=True, timeout=60,
            encoding="cp932", errors="replace",
        )
        if _res2.returncode != 0 or not _pdf_path.exists():
            _pdf_debug_log(
                f"pdftk抽出失敗\nfull: {_full_pdf}\npage: {page_num}\n"
                f"exit: {_res2.returncode}\nstderr:\n{_res2.stderr}"
            )
            return False, f"ページ抽出失敗(p{page_num}): {(_res2.stderr or '').strip()[:300]}"

        _pdf_debug_log(f"成功 (LibreOffice方式)\nxlsx: {_abs_path}\npdf : {_pdf_path}\npage: {page_num}")
        return True, pdf_path

    except subprocess.TimeoutExpired:
        return False, "PDF出力タイムアウト（LibreOffice変換180秒）"
    except Exception as _e:
        return False, f"PDF出力エラー [{type(_e).__name__}]: {_e}"


def _export_pdf_via_com(file_path: str, page_num: int, pdf_path: str) -> tuple:
    """Excel COM で PDF 出力。ハイパーリンク警告をレジストリで一時無効化してから実行。"""
    import tempfile, shutil as _shutil, subprocess as _sp, sys as _sys, json as _json
    if not Path(file_path).exists():
        return False, f"ファイルが見つかりません: {file_path}"
    tmp_dir = None
    try:
        tmp_dir  = tempfile.mkdtemp(dir=os.environ.get("TEMP", tempfile.gettempdir()))
        import re as _re_pdf, zipfile as _zf
        safe_name = _re_pdf.sub(r'[^\w.]', '_', Path(file_path).name)
        tmp_xlsx = str(Path(tmp_dir) / safe_name)

        # externalLinks を除去した xlsx を TEMP に作成
        _ext_pat = _re_pdf.compile(r'externalLink', _re_pdf.IGNORECASE)
        with _zf.ZipFile(file_path, 'r') as _zin,              _zf.ZipFile(tmp_xlsx, 'w', _zf.ZIP_DEFLATED) as _zout:
            for _item in _zin.infolist():
                _data = _zin.read(_item.filename)
                _nm   = _item.filename
                if 'externalLinks' in _nm:          # externalLinks ファイルをスキップ
                    continue
                if _nm == 'xl/_rels/workbook.xml.rels':   # 参照も削除
                    _txt = _data.decode('utf-8')
                    _txt = _re_pdf.sub(r'<Relationship[^>]*externalLink[^>]*/>', '', _txt)
                    _data = _txt.encode('utf-8')
                if _nm == 'xl/workbook.xml':              # externalReferences タグ削除
                    _txt = _data.decode('utf-8')
                    _txt = _re_pdf.sub(r'<externalReferences[^>]*>.*?</externalReferences>', '', _txt, flags=_re_pdf.DOTALL)
                    _data = _txt.encode('utf-8')
                if _nm == '[Content_Types].xml':           # ContentTypes から除去
                    _txt = _data.decode('utf-8')
                    _txt = _re_pdf.sub(r'<Override[^>]*externalLink[^>]*/>', '', _txt)
                    _data = _txt.encode('utf-8')
                _zout.writestr(_item, _data)

        args = _json.dumps({
            "xlsx": tmp_xlsx,
            "pdf":  str(pdf_path),
            "page": page_num,
        })
        # レジストリでハイパーリンク警告を一時無効 → COM実行 → 復元
        _script = (
            "import json,pythoncom,win32com.client,sys,winreg\n"
            "a=json.loads(sys.argv[1])\n"
            # ハイパーリンク警告を一時無効化
            "saved={}\n"
