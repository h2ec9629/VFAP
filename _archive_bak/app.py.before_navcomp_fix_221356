# VFDB2 全列読み込み（データベースページ用、5分キャッシュ）
# ══════════════════════════════════════════════════════════
@st.cache_data(ttl=300, show_spinner="VFDB2 読み込み中...")
def load_vfdb_full() -> pd.DataFrame:
    """VFDB2シートを全列そのままDataFrameで返す"""
    if not SGT_PATH.exists():
        return pd.DataFrame()
    wb = tmp_path = None
    try:
        wb, tmp_path = open_workbook_safely(
            SGT_PATH, keep_vba=True, data_only=True, read_only=True)
        ws = wb["VFDB2"]
        rows = list(ws.iter_rows(values_only=True))
        if not rows:
            return pd.DataFrame()
        header = [str(h) if h is not None else f"列{i+1}" for i, h in enumerate(rows[0])]
        seen: dict = {}
        deduped = []
        for h in header:
            if h in seen:
                seen[h] += 1
                deduped.append(f"{h}.{seen[h]}")
            else:
                seen[h] = 0
                deduped.append(h)
        data = [list(r) for r in rows[1:] if any(v is not None for v in r)]
        df = pd.DataFrame(data, columns=deduped)
        if "品目コード" in df.columns:
            df = df[df["品目コード"].notna() & (df["品目コード"].astype(str) != "")]
        return df.reset_index(drop=True)
    except Exception as e:
        st.error(f"VFDB2 全列読み込みエラー: {e}")
        return pd.DataFrame()
    finally:
        try:
            if wb is not None:
                wb.close()
        except Exception:
            pass
        cleanup_tmp(tmp_path)

