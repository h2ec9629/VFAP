def detect_onedrive_work() -> Path | None:
    """OneDriveのworkフォルダを環境変数ベースで確実に特定する"""
    # Windows が自動セットする環境変数を優先（フォルダ名が何でも対応）
    for ev in ("OneDriveConsumer", "OneDrive", "ONEDRIVE"):
        od = os.environ.get(ev, "").strip()
        if od:
            p = Path(od) / "work"
            if p.exists():
                return p
    # フォールバック：USERPROFILE下のOneDrive*フォルダを総当たり
    up = os.environ.get("USERPROFILE", "")
    if up:
        for d in Path(up).iterdir() if Path(up).exists() else []:
            if d.name.lower().startswith("onedrive") and (d / "work").exists():
                return d / "work"
    return None


