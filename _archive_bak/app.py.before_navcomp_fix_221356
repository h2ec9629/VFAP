def _find_edge_or_chrome():
    """msedge.exe / chrome.exe を探す（Windows標準のEdge優先）"""
    _cands = [
        Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")) / "Microsoft" / "Edge" / "Application" / "msedge.exe",
        Path(os.environ.get("ProgramFiles", r"C:\Program Files")) / "Microsoft" / "Edge" / "Application" / "msedge.exe",
        Path(os.environ.get("ProgramFiles", r"C:\Program Files")) / "Google" / "Chrome" / "Application" / "chrome.exe",
        Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)")) / "Google" / "Chrome" / "Application" / "chrome.exe",
    ]
    for _c in _cands:
        try:
            if _c.exists():
                return str(_c)
        except Exception:
            pass
    for _n in ("msedge", "chrome", "google-chrome", "chromium"):
        _w = shutil.which(_n)
        if _w:
            return _w
    return None


def _html_to_pdf_edge(html_text: str, out_pdf: Path, landscape: bool = False) -> tuple:
    """populate済みHTML文字列を Edge/Chrome 画面なしモードでPDF化し out_pdf に保存。
    A4・余白を @page で固定。戻り値 (ok, msg)。"""
    _exe = _find_edge_or_chrome()
    if not _exe:
        return False, "Edge/Chrome が見つかりません（PDF化の謎の力が使えません）"
    import tempfile as _tf, uuid as _uuid
    _tmpdir = Path(_tf.gettempdir()) / "vfap_pdf"
    try:
        _tmpdir.mkdir(parents=True, exist_ok=True)
    except Exception:
        pass
    _page_css = ("<style>@page{size:A4 %s;margin:6mm;} "
                 "html,body{-webkit-print-color-adjust:exact;print-color-adjust:exact;}</style>"
                 ) % ("landscape" if landscape else "portrait")
    if "</head>" in html_text:
        html_text = html_text.replace("</head>", _page_css + "</head>", 1)
    else:
        html_text = _page_css + html_text
    _tmp_html = _tmpdir / ("_render_" + _uuid.uuid4().hex[:8] + ".html")
    _tmp_html.write_text(html_text, encoding="utf-8")
    _user_dir = _tmpdir / ("ud_" + _uuid.uuid4().hex[:8])
    try:
        out_pdf.parent.mkdir(parents=True, exist_ok=True)
    except Exception:
        pass
    try:
        _r = subprocess.run(
            [_exe, "--headless=new", "--disable-gpu", "--no-pdf-header-footer",
             "--user-data-dir=" + str(_user_dir),
             "--virtual-time-budget=10000",
             "--print-to-pdf=" + str(out_pdf), _tmp_html.as_uri()],
            capture_output=True, text=True, timeout=120,
            encoding="cp932", errors="replace",
        )
        if not out_pdf.exists():
            return False, "PDF生成失敗: " + (_r.stderr or "")[:300]
        return True, str(out_pdf)
    except Exception as _e:
        return False, str(_e)
    finally:
        try:
            _tmp_html.unlink(missing_ok=True)
        except Exception:
            pass

