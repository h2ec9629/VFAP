def build_vfdb_spec_by_name() -> dict:
    """vfdb.json を 品名(空白除去)→品目スペック dict に整形（加工記録モーダル左パネル用）"""
    import re as _re2, unicodedata as _ud
    _up2 = os.environ.get("USERPROFILE", "")
    candidates = [
        BASE_DIR / "vfdb.json",
        *([((detect_onedrive_work() or Path()) / "VFAP" / "vfdb.json")] if _up2 else []),
        Path(__file__).resolve().parent / "vfdb.json",
    ]
    p = next((c for c in candidates if c.exists()), None)
    if p is None:
        return {}
    try:
        recs = json.loads(p.read_text("utf-8"))
    except Exception:
        return {}
    def _norm(s):
        return _re2.sub(r"\s+", "", _ud.normalize("NFKC", str(s if s is not None else "")))
    def _v(x):
        return "" if x is None else x
    out = {}
    for r in recs:
        key = _norm(r.get("品名"))
        if not key:
            continue
        out[key] = {
            "center": _v(r.get("センター")),
            "setdan": _v(r.get("切断寸法")),
            "toru":   _v(r.get("取数")),
            "ondo":   _v(r.get("温度換算")),
            "plus":   _v(r.get("上限公差")),
            "minus":  _v(r.get("下限公差")),
            "hako":   _v(r.get("箱名")),
            "irisu":  _v(r.get("梱包")),
            "hakosu": _v(r.get("梱包箱使用枚数")),
            "hoho1":  _v(r.get("梱包方法")),
            "biko":   _v(r.get("備考")),
            "hoho2":  _v(r.get("備考１")),
            "hoho3":  _v(r.get("備考２")),
            "kosuu":  _v(r.get("切断工数")),  # 切断工数(本/h) — 日程表の進捗工数表示用
        }
    return out


