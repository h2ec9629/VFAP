def find_excel_exe() -> str | None:
    """このPCのExcel.exeを探す。見つからなければNone。"""
    candidates = [
        r"C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE",
        r"C:\Program Files (x86)\Microsoft Office\root\Office16\EXCEL.EXE",
        r"C:\Program Files\Microsoft Office\Office16\EXCEL.EXE",
        r"C:\Program Files (x86)\Microsoft Office\Office16\EXCEL.EXE",
    ]
    for c in candidates:
        if Path(c).exists():
            return c
    # レジストリ既定から探す（App Paths）
    try:
        import winreg
        key = winreg.OpenKey(
            winreg.HKEY_LOCAL_MACHINE,
            r"SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\excel.exe",
        )
        val, _ = winreg.QueryValueEx(key, None)
        if val and Path(val).exists():
            return val
    except Exception:
        pass
    return None

# 起動時に1回だけ探してキャッシュ
EXCEL_EXE = find_excel_exe()

def open_in_excel(file_path: str) -> tuple:
    """
    ファイルをデスクトップ版Excelで直接開く。(成功bool, メッセージ) を返す。
    os.startfile だと OneDrive/既定アプリの謎の力でブラウザ版が開くことが
    あるため、Excel.exe を名指しで起動する。見つからなければ os.startfile に戻す。
    """
    p = Path(file_path)
    if not file_path or not p.exists():
        return False, "ファイルが見つかりませんでした"
    try:
        if EXCEL_EXE:
            subprocess.Popen([EXCEL_EXE, str(p.resolve())])
        else:
            os.startfile(str(p.resolve()))  # Excelが見つからない場合の保険
        return True, p.name
    except Exception as e:
        return False, str(e)

