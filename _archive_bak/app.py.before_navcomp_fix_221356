def paste_shizusho_via_com(sgt_path: Path, target_items: list) -> tuple:
    """
    SGT.xlsm「指図書」シートの 38:56 行を各指示書ファイルに貼り付ける。
    target_items: [(file_path_str, page_num), ...]
    戻り値: (成功: bool, メッセージ: str)
    """
    if not target_items:
        return True, "貼り付け対象なし"
    try:
        import pythoncom
        import win32com.client
        pythoncom.CoInitialize()
    except ImportError:
        return False, "pywin32 未インストール（pip install pywin32）"

    new_instance = False
    excel = None
    try:
        excel, new_instance = _get_or_open_excel()

        # ダイアログを全て抑制・描画停止
        excel.DisplayAlerts    = False
        excel.ScreenUpdating   = False
        excel.AskToUpdateLinks = False

        try:
            wb_sgt = _get_or_open_wb(excel, sgt_path)
            if wb_sgt is None:
                return False, "SGT.xlsm を開けませんでした"

            ws_src = wb_sgt.Sheets("指図書")
            pasted = 0
            current_path = None
            wb_tgt = None

            for file_path, page_num in target_items:
                if not Path(file_path).exists():
                    continue
                try:
                    page_num = int(page_num or 1)
                except Exception:
                    page_num = 1
                paste_row = 38 + (page_num - 1) * 57

                if current_path != file_path:
                    if wb_tgt is not None:
                        wb_tgt.Save()
                        wb_tgt.Close(False)
                        wb_tgt = None
                    wb_tgt = excel.Workbooks.Open(
                        file_path,
                        UpdateLinks=0    # リンク更新ダイアログを抑制
                    )
                    current_path = file_path

                ws_src.Rows("38:56").Copy(
                    Destination=wb_tgt.Sheets(1).Rows(str(paste_row))
                )
                excel.CutCopyMode = False   # クリップボードを即解放

                pasted += 1

            if wb_tgt is not None:
                wb_tgt.Save()
                wb_tgt.Close(False)

        finally:
            # 必ず元に戻す
            excel.DisplayAlerts  = True
            excel.ScreenUpdating = True
            if new_instance:
                excel.Quit()

        return True, f"{pasted}件に指図書を貼り付けました"

    except Exception as e:
        if new_instance and excel:
            try:
                excel.Quit()
            except Exception:
                pass
        return False, f"貼り付けエラー: {e}"

