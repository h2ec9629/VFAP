@st.cache_data(ttl=60, show_spinner="樹脂指示書 スキャン中...")
# ══════════════════════════════════════════════════════════
# 指示書スキャン用 mtime キャッシュ（jushi_scan_cache.json）
# ══════════════════════════════════════════════════════════
def _jushi_cache_default(obj):
    """datetime/date を JSON シリアライズ"""
    from datetime import datetime as _dt, date as _d
    if isinstance(obj, _dt):
        return {"__dt__": obj.isoformat()}
    if isinstance(obj, _d):
        return {"__d__": obj.isoformat()}
    raise TypeError(f"Not serializable: {type(obj)}")

def _jushi_cache_hook(d: dict):
    """JSON デシリアライズ時に datetime を復元"""
    from datetime import datetime as _dt, date as _d
    if "__dt__" in d:
        return _dt.fromisoformat(d["__dt__"])
    if "__d__" in d:
        return _d.fromisoformat(d["__d__"])
    return d

def _jushi_cache_load() -> dict:
    if not JUSHI_CACHE_PATH.exists():
        return {}
    try:
        with open(JUSHI_CACHE_PATH, encoding="utf-8") as _f:
            return json.load(_f, object_hook=_jushi_cache_hook)
    except Exception:
        return {}

def _jushi_cache_save(cache: dict) -> None:
    try:
        with open(JUSHI_CACHE_PATH, "w", encoding="utf-8") as _f:
            json.dump(cache, _f, ensure_ascii=False, default=_jushi_cache_default)
    except Exception:
        pass

def _scan_jushi_raw(vfdb: dict) -> list:
    """
    樹脂指示書フォルダを全件スキャン。
    ファイルのmtimeが変わっていなければ jushi_scan_cache.json から読み込み、
    xlsx を開く処理をスキップする。
    フィルタなし版。scan_jushi() から呼び出す。
    """
    results = []
    if not JUSHI_DIR.exists():
        return results

    # ─── キャッシュ読み込み ───
    cache     = _jushi_cache_load()   # {fname:mtime: [records]}
    new_cache = {}
    cache_updated = False

    two_months_ago = datetime.now() - timedelta(days=60)

    for fpath in sorted(JUSHI_DIR.glob("*.xlsx")):
        if fpath.name.startswith("~$"):
            continue
        fname = fpath.name

        # ─── リネーム（YYMMDD_ 形式でなければ）───
        if not (len(fname) >= 7 and fname[:6].isdigit() and fname[6] == "_"):
            try:
                cdate    = datetime.fromtimestamp(fpath.stat().st_ctime)
                new_name = cdate.strftime("%y%m%d") + "_" + fname
                new_path = fpath.parent / new_name
                if not new_path.exists():
                    fpath.rename(new_path)
                fpath = new_path
                fname = new_path.name
            except Exception:
                continue

        # ─── 日付フィルタ（2ヶ月以内）───
        try:
            fdate = datetime(2000 + int(fname[:2]), int(fname[2:4]), int(fname[4:6]))
            if fdate < two_months_ago:
                continue
        except Exception:
            continue

        # ─── mtimeキャッシュチェック ───
        try:
            mtime = round(fpath.stat().st_mtime, 3)
        except Exception:
            mtime = 0.0
        cache_key = f"{fname}:{mtime}"

        if cache_key in cache:
            # キャッシュヒット：xlsx を開かずにレコードを再利用
            # vfdb は安価なdict引き当てなので毎回マージする
            cached_recs = cache[cache_key]
            for rec in cached_recs:
                code = rec.get("品目コード", "")
                vf   = vfdb.get(str(code), {}) if code else {}
                rec["品名"]      = vf.get("品名",      rec.get("品名",      ""))
                rec["単価"]      = vf.get("単価",      rec.get("単価",      ""))
                rec["切断工数"]  = vf.get("切断工数",  rec.get("切断工数",  ""))
                rec["業態"]      = vf.get("業態",      rec.get("業態",      ""))
                rec["梱包"]      = vf.get("梱包",      rec.get("梱包",      ""))
                rec["取数"]      = vf.get("取数",      rec.get("取数",      ""))
                rec["温度換算"]  = vf.get("温度換算",  rec.get("温度換算",  ""))
                rec["下限公差"]  = vf.get("下限公差",  rec.get("下限公差",  ""))
                rec["上限公差"]  = vf.get("上限公差",  rec.get("上限公差",  ""))
                rec["梱包方法"]  = vf.get("梱包方法",  rec.get("梱包方法",  ""))
                rec["梱包箱"]    = vf.get("梱包箱",    rec.get("梱包箱",    ""))
                rec["切断寸法"]  = vf.get("切断寸法",  rec.get("切断寸法",  ""))
            results.extend(cached_recs)
            new_cache[cache_key] = cached_recs
            continue   # xlsx を開かずに次のファイルへ

        # ─── xlsx 読み取り（57行ごとに1案件）───
        wb = tmp_path = None
        file_records = []
        try:
            wb, tmp_path = open_workbook_safely(
                fpath, data_only=True, read_only=True)
            ws = wb.worksheets[0]
            row_offset = 0
            page       = 1

            while True:
                b3  = ws.cell(3  + row_offset, 2).value
                b5  = ws.cell(5  + row_offset, 2).value
                b7  = ws.cell(7  + row_offset, 2).value
                b10 = ws.cell(10 + row_offset, 2).value
                h10 = ws.cell(10 + row_offset, 8).value

                if not any([b3, b5, b7, b10, h10]):
                    break

                vf = vfdb.get(str(b3), {}) if b3 else {}

                file_records.append({
                    "file_path"  : str(fpath),
                    "ファイル名" : fname,
                    "指図書No"   : str(b7)  if b7  else "",
                    "品目番号"   : str(b5)  if b5  else "",
